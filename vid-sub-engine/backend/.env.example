# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/subzi
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/subzi
MONGO_URI=mongodb://127.0.0.1:27017/subzi

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Upstash (production):
# REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6380
# REDIS_TLS=true

# ─── Storage ──────────────────────────────────────────────────────────────────
UPLOADS_DIR=uploads

# ─── AI / Transcription ───────────────────────────────────────────────────────
# Default local Whisper model (tiny | base | small | medium | large-v3)
WHISPER_MODEL=medium

# Python binary path (if using local Whisper)
PYTHON_BIN=python

# Gemini API — get free key at https://aistudio.google.com
# When set, users can select "Gemini Flash" for instant (no GPU) transcription
GEMINI_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# For local dev use * — set to your Vercel domain in production
CORS_ORIGIN=*

# ─── Optional ─────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
WHISPERX_ENABLED=false
DEMUCS_ENABLED=false
